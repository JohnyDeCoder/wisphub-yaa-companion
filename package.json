{
  "name": "wisphub-yaa-companion",
  "version": "1.4.0",
  "description": "Extensión de productividad para WispHub — (uso interno Yaa Internet)",
  "homepage": "https://github.com/JohnyDeCoder/wisphub-yaa-companion#readme",
  "bugs": {
    "url": "https://github.com/JohnyDeCoder/wisphub-yaa-companion/issues"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "webpack --watch --mode=development",
    "dev:firefox": "webpack --watch --mode=development --env target=firefox",
    "build:dev": "node scripts/build-dev.js",
    "build:prod": "node scripts/build-production.js",
    "build": "webpack --mode=production",
    "build:firefox": "webpack --mode=production --env target=firefox",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run lint && npm run test:run && npm run build && npm run build:firefox",
    "security:audit": "npm audit --audit-level=high",
    "commitlint": "commitlint --edit",
    "clean": "rimraf dist",
    "release:prepare": "node scripts/prepare-release.js",
    "release:publish:firefox": "node scripts/publish-firefox-update.js",
    "changelog:generate": "node scripts/generate-changelog.js",
    "update:prepare": "node scripts/prepare-release.js",
    "update:publish": "node scripts/publish-firefox-update.js"
  },
  "keywords": [
    "wisphub",
    "yaa internet",
    "browser-extension",
    "chrome-extension",
    "edge-extension",
    "firefox-addon",
    "opera-extension",
    "manifest-v3",
    "formatter",
    "productivity"
  ],
  "author": "JohnyDeCoder",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/JohnyDeCoder/wisphub-yaa-companion.git"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.0.3",
    "eslint-plugin-boundaries": "^6.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "vitest": "^4.1.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions"
  ]
}
